generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[]
}

model Project {
  id          String          @id @default(cuid())
  name        String
  appName     String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  screenshots Screenshot[]
  locales     ProjectLocale[]
  exportJobs  ExportJob[]

  @@index([userId])
}

model Screenshot {
  id           String           @id @default(cuid())
  projectId    String
  order        Int
  templateType String
  templateData Json
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  texts        ScreenshotText[]

  @@index([projectId])
}

model ScreenshotText {
  id           String            @id @default(cuid())
  screenshotId String
  key          String
  screenshot   Screenshot        @relation(fields: [screenshotId], references: [id], onDelete: Cascade)
  translations TextTranslation[]

  @@index([screenshotId])
}

model TextTranslation {
  id               String         @id @default(cuid())
  screenshotTextId String
  locale           String
  text             String
  isAutoTranslated Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  screenshotText   ScreenshotText @relation(fields: [screenshotTextId], references: [id], onDelete: Cascade)

  @@unique([screenshotTextId, locale])
  @@index([screenshotTextId])
}

model ProjectLocale {
  id        String  @id @default(cuid())
  projectId String
  locale    String
  isBase    Boolean @default(false)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@index([projectId])
}

model ExportJob {
  id          String   @id @default(cuid())
  projectId   String
  status      String   @default("pending")
  platforms   Json
  locales     Json
  format      String   @default("png")
  quality     Int      @default(90)
  totalFiles  Int      @default(0)
  completedFiles Int   @default(0)
  resultUrl   String?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
